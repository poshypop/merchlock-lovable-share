PUBLIC_SITE_URL=http://127.0.0.1:5174

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

SESSION_SECRET=replace-with-long-random-session-hmac-secret
STEAM_WEB_API_KEY=optional-steam-web-api-key-for-profile-avatar

# Shopify headless checkout + orders/paid webhook. Full setup: SHOPIFY_INTEGRATION.md
SHOPIFY_STORE_PERMANENT_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_TOKEN=replace-with-storefront-api-access-token
SHOPIFY_WEBHOOK_SECRET=replace-with-orders-paid-webhook-signing-secret
SHOPIFY_API_VERSION=2025-07
# Must be a ProductVariant GID from YOUR store, e.g. gid://shopify/ProductVariant/1234567890
SHOPIFY_REM_VARIANT_ID=gid://shopify/ProductVariant/your-variant-id

REDEEM_ADMIN_TOKEN=replace-with-long-random-admin-token
REDEEM_CODE_HASH_SECRET=replace-with-long-random-code-hmac-secret

# Local-only Steam session shortcut for testing:
# /api/auth/steam/dev?steamid=76561198000000000
ALLOW_DEV_STEAM_LOGIN=0
